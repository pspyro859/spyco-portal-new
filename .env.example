# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=spyco_portal
DB_USER=spyco_user
DB_PASS=your_secure_password_here

# Application Settings
APP_NAME=Spyco Portal
APP_ENV=production
APP_DEBUG=false
APP_URL=http://portal.spyco.com.au

# Security
SESSION_TIMEOUT=3600
PASSWORD_MIN_LENGTH=8

# API Settings
API_VERSION=v1
CORS_ENABLED=true